# OpenAI Compatible API Configuration
# Fill in your values below

# Base URL for the API (e.g., https://api.openai.com/v1, https://api.groq.com/openai/v1, etc.)
OPENAI_BASE_URL=https://api.blackbox.ai/v1/chat/completions

# Your API key
OPENAI_API_KEY=sk-AgINa5WVYQ2Bg5rdeCW9lw

# Model name to use (e.g., gpt-4o, gpt-4o-mini, llama3-70b-8192, etc.)
OPENAI_MODEL=blackboxai/moonshotai/kimi-k2.6

# Optional: Max concurrent requests (default: 3)
MAX_CONCURRENT=1

# Optional: Delay between requests in seconds (default: 0.5)
REQUEST_DELAY=0.5
